# Evolution API (WhatsApp)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=your_evolution_api_key_here
EVOLUTION_INSTANCE_NAME=ncam_instance

# Discord Bot
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_IDS=123456789,987654321
DISCORD_CHANNEL_IDS=  # Opcional, deixe vazio para todos os canais

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=4096

# E-mail Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
EMAIL_RECIPIENT=report@ncam.com.br
EMAIL_FROM_NAME=NCam Weekly Intel

# Database
DATABASE_URL=sqlite:///./ncam_intel.db

# Scheduler
SCHEDULER_ENABLED=true
REPORT_SCHEDULE_CRON=0 8 * * MON
COLLECTION_TIMEZONE=America/Sao_Paulo

# Coleta de Mensagens
COLLECTION_DAYS=Monday,Tuesday,Wednesday,Thursday,Friday
LOOKBACK_DAYS=7

# Logging
LOG_LEVEL=INFO
LOG_FILE=ncam_intel.log
